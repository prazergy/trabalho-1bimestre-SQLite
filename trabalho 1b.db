SELECT l.id_locacao, c.nome_razao, v.placa, e.nome_estacionamento, l.status_locacao, l.valor_previsto FROM locacoes l 
JOIN clientes c ON c.id_cliente = l.id_cliente JOIN veiculos v ON v.id_veiculo = l.id_veiculo LEFT JOIN estacionamentos e ON 
e.id_estacionamento = v.id_estacionamento_atual ORDER BY l.id_locacao;